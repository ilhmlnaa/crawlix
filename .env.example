# Server Configuration
NODE_ENV=development
PORT=3001
TRUST_PROXY=1

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=scraper:

# Cache Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600

# Scraper Configuration
SCRAPER_DEFAULT_STRATEGY=cloudscraper
SCRAPER_DEFAULT_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_USE_PROXY=false
SCRAPER_PROXY_URL=
SCRAPER_MAX_BATCH_SIZE=5

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MAX_BROWSERS=2
PLAYWRIGHT_IDLE_TIMEOUT=300000
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# Rate Limit Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BYPASS_KEY=your-secret-key

# CORS Configuration
CORS_ORIGIN=*

# Production URL (optional)
PRODUCTION_URL=

# OpenTelemetry Configuration (optional) (signoz)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
OTEL_TRACES_EXPORTER=otlp
OTEL_SERVICE_NAME=crawlix
OTEL_SERVICE_VERSION=1.0.0