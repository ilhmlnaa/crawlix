{
  "name": "crawlix",
  "version": "1.0.0",
  "description": "A unified web scraping API service built with Node.js, Express, and TypeScript, featuring multiple strategies (Cloudscraper & Playwright), Redis caching, and rate limiting.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --watch src -e ts,js,json --exec \"tsx src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "scraping",
    "crawler",
    "api",
    "playwright",
    "cloudscraper",
    "redis",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cloudscraper": "^4.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "joi": "^18.0.2",
    "playwright": "^1.58.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nod": "^0.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
